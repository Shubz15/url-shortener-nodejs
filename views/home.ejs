<!DOCTYPE html>
<html lang="en">

<head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>Short-Url</title>

       <style>
        
    *{
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, sans-serif;
    }

    body{
        background-color: #f4f4f4;
        padding: 30px;
    }

    h1{
        text-align: center;
        margin-bottom: 20px;
        color: #333;
    }

    form{
        background: white;
        padding: 20px;
        border-radius: 8px;
        width: 500px;
        margin: auto;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    label{
        font-weight: bold;
        margin-right: 10px;
    }

    input{
        width: 250px;
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 4px;
    }

    button{
        padding: 8px 15px;
        background: #007bff;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        margin-left: 10px;
    }

    button:hover{
        background: #0056b3;
    }

    p{
        text-align: center;
        margin-top: 15px;
        font-weight: bold;
        color: green;
    }

    table{
        width: 80%;
        margin: 30px auto;
        border-collapse: collapse;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    th{
        background: #007bff;
        color: white;
    }

    th, td{
        padding: 12px 25px;
        text-align: center;
        border: 1px solid #ddd;
    }

    tr:nth-child(even){
        background: #f9f9f9;
    }

    tr:hover{
        background: #f1f1f1;
    }

    </style>
</head>

<body>
      <nav>
            <a href="/user/logout">Logout</a>
      </nav>
      <h1>URL Shortener</h1>
      
      <% if (locals.error) { %>
    <p class="error"><%= error %></p>
<% } %>

      <div>
            <form action="/url" method="post">
                  <label for="">Enter Your URL</label>
                  <input type="text" name="url" placeholder="www.example.com">

                  <button type="submit">Generate</button>
            </form>
      </div>

      <% if (locals.id) { %>
            <p>URL Generated: http://localhost:8001/url/<%= id %>
            </p>
            <% } %>

      <div>
            <% if (locals.urls) { %>
                  <table>
                        <thead>
                              <th>S.No</th>
                              <th>Short ID</th>
                              <th>Redirect</th>
                              <th>Clicks</th>
                              <th>Created At</th>
                              <th>Delete</th>
                        </thead>
                        <tbody>
                              <% urls.forEach((url,index) => { %>
                              <tr>
                               <td><%= index +1 %></td>
                               <td><%=url.shortId%></td>
                               <td><%= url.redirectUrl %></td>
                               <td><%= url.visitHistory.length%></td>   
                             <td>
  <%= new Date(url.createdAt).toLocaleDateString() %>
</td>   
                               <td>
    <form action="/url/delete/<%= url._id %>" method="POST">
        <button type="submit">Delete</button>
    </form>
</td>
                              </tr>
                              <% }) %>
                        </tbody>
                  </table>
            <% } %>
            
      </div>
</body>

</html>